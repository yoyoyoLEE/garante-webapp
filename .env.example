# Sviluppo locale: chiave OpenRouter (opzionale se usi emulator Functions + proxy)
# NON committare valori reali. In produzione (Firebase Hosting) la chiave è solo nel Secret OPENROUTER_API_KEY.
# VITE_OPENROUTER_API_KEY=

# ID progetto Firebase (stesso valore in .firebaserc) — serve al proxy Vite verso l'emulator Functions
# VITE_FIREBASE_PROJECT_ID=your-firebase-project-id

# Forza sempre il proxy /api/openrouter anche se la chiave è presente (debug)
# VITE_USE_OPENROUTER_PROXY=false
