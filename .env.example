# Sviluppo locale: chiave OpenRouter (opzionale se usi emulator Functions + proxy)
# NON committare valori reali. In produzione (Firebase Hosting) la chiave è solo nel Secret OPENROUTER_API_KEY.
# VITE_OPENROUTER_API_KEY=

# Firebase Web SDK (Authentication) — da Console → Impostazioni progetto → Le tue app
# Obbligatori per login e per il proxy OpenRouter (token verificato sulla Cloud Function).
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
# VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

# Forza sempre il proxy /api/openrouter anche se la chiave è presente (debug)
# VITE_USE_OPENROUTER_PROXY=false
